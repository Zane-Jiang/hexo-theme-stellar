.widget-wrapper.content-stats
  .widget-body
    background: var(--bg-a20)
    border-radius: $border-card-s
    padding: 10px 12px
    display: flex
    flex-direction: column
    gap: 8px

  .summary
    border-radius: 10px
    padding: 10px 14px
    background: linear-gradient(135deg, var(--theme-a20), var(--theme-a10))
    display: flex
    align-items: baseline
    gap: 8px

  .summary-label
    color: var(--text-p2)
    font-size: $fs-12

  .summary-value
    color: var(--theme)
    font-weight: 700
    font-size: $fs-20
    letter-spacing: -0.5px

  .stat-item
    display: flex
    align-items: center
    justify-content: space-between
    line-height: 1.2
    background: var(--bg-a50)
    border-radius: 8px
    padding: 9px 12px
    text-decoration: none
    trans1 background

    &:hover
      background: var(--bg-a100)

  .left
    display: inline-flex
    align-items: center
    gap: 8px

  .right
    display: inline-flex
    align-items: center
    gap: 6px

  .dot
    display: inline-flex
    align-items: center
    justify-content: center
    width: 1.6rem
    height: 1.6rem
    border-radius: 8px
    background: var(--theme-a20)
    color: var(--theme)
    flex-shrink: 0

    svg
      width: 1rem
      height: 1rem
      fill: currentColor

  .label
    color: var(--text-p2)
    font-size: $fs-14

  .value
    color: var(--text-p1)
    font-weight: 700
    font-size: $fs-15

  .arrow
    color: var(--text-p3)
    font-size: $fs-12
